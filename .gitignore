# =============================================================
#  print3d-shop — monorepo .gitignore
# =============================================================

# -------------------------------------------------------------
# Python / Django (backend/)
# -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy
.mypy_cache/
.dmypy.json

# celery
celerybeat-schedule
celerybeat.pid

# Environment variables
.env
.env.*
!.env.example

# -------------------------------------------------------------
# Node / React / Vite (storefront/ and admin-panel/)
# -------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local

# Vite
.vite/

# Package manager locks (keep only one — we use npm)
yarn.lock
pnpm-lock.yaml

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output/

# -------------------------------------------------------------
# Editors & OS
# -------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# -------------------------------------------------------------
# Misc
# -------------------------------------------------------------
*.bak
*.swp
*.swo
*.tmp
.cache/